<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram id="deployment" name="Deployment">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Docker Host -->
        <mxCell id="host" value="Docker Host" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8E8E8;strokeColor=#666666;fontStyle=1;fontSize=14;verticalAlign=top;align=left;spacingLeft=10;spacingTop=10;container=1;collapsible=0;expandable=0;" parent="1" vertex="1">
          <mxGeometry x="20" y="20" width="1060" height="780" as="geometry"/>
        </mxCell>

        <!-- External World -->
        <mxCell id="ext" value="External / Internet" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontStyle=1;fontSize=12;dashed=1;container=1;collapsible=0;expandable=0;" parent="1" vertex="1">
          <mxGeometry x="40" y="60" width="1020" height="200" as="geometry"/>
        </mxCell>

        <!-- Internal Network -->
        <mxCell id="int" value="Internal Docker Network (concierge_default)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontStyle=1;fontSize=12;container=1;collapsible=0;expandable=0;" parent="1" vertex="1">
          <mxGeometry x="40" y="280" width="1020" height="500" as="geometry"/>
        </mxCell>

