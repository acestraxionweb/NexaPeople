# ── LLM Provider ──
OPENCODE_ZEN_API_KEY=sk-your-zen-api-key

# ── Vector Database ──
PINECONE_API_KEY=pcsk-your-pinecone-key

# ── Telegram Bots ──
BOT_TOKEN_A=123456:ABC-DEF...
BOT_TOKEN_C=your_bot_token_here

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── Admin Access ──
GOOGLE_ADMIN_EMAILS=admin@example.com

# ── Optional Overrides ──
# JWT_SECRET=change-me-to-a-random-secret
# FRONTEND_URL=http://localhost:8080
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
# VITE_CLIENT_API_URL=http://localhost:8000
