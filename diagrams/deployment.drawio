        <mxCell id="conn_telegram_bot" value="Polling / Updates" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6C8EBF;fontSize=10;" parent="1" source="telegram_api" target="bot_a" edge="1">
