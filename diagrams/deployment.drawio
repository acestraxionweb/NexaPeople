          <mxGeometry x="120" y="40" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- External: Pinecone -->
        <mxCell id="pinecone_ext" value="Pinecone&#xa;(Vector DB)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" parent="ext" vertex="1">
          <mxGeometry x="700" y="40" width="120" height="50" as="geometry"/>
        </mxCell>

        <!-- External: Zen API -->
        <mxCell id="zen_ext" value="Zen API&#xa;(LLM Provider)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" parent="ext" vertex="1">
