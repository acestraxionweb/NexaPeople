        <!-- External: Dashboard Admin -->
        <mxCell id="admin_user" value="Dashboard Admin" style="shape=actor;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;" parent="ext" vertex="1">
          <mxGeometry x="30" y="100" width="40" height="60" as="geometry"/>
        </mxCell>

        <!-- Internal: db -->
        <mxCell id="db" value="&lt;b&gt;Main DB (db)&lt;/b&gt;&#xa;postgres:16-alpine&#xa;&#xa;Port: 5432&#xa;Vol: pgdata&#xa;&#xa;Tables: tenants,&#xa;tenant_users, memories" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;" parent="int" vertex="1">
          <mxGeometry x="30" y="30" width="160" height="120" as="geometry"/>
        </mxCell>

        <!-- Internal: litellm-db -->
        <mxCell id="litellm_db" value="&lt;b&gt;LiteLLM DB (litellm-db)&lt;/b&gt;&#xa;postgres:16-alpine&#xa;&#xa;Vol: litellm-pgdata&#xa;&#xa;Tables: spend logs,&#xa;virtual keys, configs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;" parent="int" vertex="1">
