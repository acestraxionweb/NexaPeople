# Required
OPENCODE_ZEN_API_KEY=sk-...
PINECONE_API_KEY=pcsk_...

# Telegram bot tokens (add one per client)
BOT_TOKEN_A=your_bot_token_here
BOT_TOKEN_C=your_bot_token_here

# Google OAuth (for dashboard login)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Admin emails (comma-separated, these get admin role on first login)
GOOGLE_ADMIN_EMAILS=admin@example.com

# Optional overrides (defaults work for local dev)
# LITELLM_MASTER_KEY=sk-litellm-master
# PINECONE_INDEX_NAME=knowledge-base
# JWT_SECRET=change-me-to-a-random-secret
# FRONTEND_URL=http://localhost:8080
# GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
# VITE_CLIENT_API_URL=http://localhost:8000
