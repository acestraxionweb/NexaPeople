        </mxCell>

        <!-- Internal: rag-api -->
        <mxCell id="rag_api" value="&lt;b&gt;RAG API (rag-api)&lt;/b&gt;&#xa;FastAPI (Python)&#xa;&#xa;Port: 8000&#xa;Vol: ./rag-api:/app&#xa;&#xa;Business logic, RAG,&#xa;auth, admin APIs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" parent="int" vertex="1">
